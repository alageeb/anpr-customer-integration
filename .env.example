# ANPR Integration Secret
ANPR_INTEGRATION_SECRET=

# Customer Database Configuration
CUSTOMER_DB_TYPE=mssql
CUSTOMER_DB_HOST=
CUSTOMER_DB_PORT=1433
CUSTOMER_DB_NAME=
CUSTOMER_DB_USER=
CUSTOMER_DB_PASSWORD=
CUSTOMER_DB_ENCRYPT=true
CUSTOMER_DB_TRUST_CERTIFICATE=false

# Mock Mode (set to true for development)
CUSTOMER_DB_MOCK_MODE=false

# Connection Timeout (ms)
CUSTOMER_DB_CONNECTION_TIMEOUT=5000
CUSTOMER_DB_REQUEST_TIMEOUT=10000

# Retry Settings
CUSTOMER_DB_MAX_RETRIES=1
CUSTOMER_DB_RETRY_DELAY_MS=1000

# Server Port
PORT=3010

# Display Client Settings (for Android TV app)
DISPLAY_SETTINGS_PIN=1234
DISPLAY_WELCOME_DURATION_SECONDS=5

# Queue Dashboard Settings
QUEUE_DASHBOARD_PIN=1234
